{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "hzl-website",
	"main": "./src/worker.ts",
	"compatibility_date": "2025-10-17",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist",
	},
	"kv_namespaces": [
		{
			"binding": "WEBSITE_CACHE",
			"id": "850478cd66e648d39db24e5aea3ec2a7"
		},
	],
	"triggers": {
		"crons": [
			"*/5 * * * *"
		],
	},
	"observability": {
		"enabled": true,
	},
	"preview_urls": true,
}