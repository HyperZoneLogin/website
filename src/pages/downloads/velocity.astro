import Layout from "@/layouts/Layout.astro";
import Button from "@/components/input/Button.astro";
---

<Layout
  title="Legacy Downloads Alias"
  description="Legacy alias route for HyperZoneLogin downloads."
  keywords={["hyperzonelogin", "downloads", "legacy-route"]}
  canonical="/downloads/velocity"
>
  <section class="mx-auto max-w-4xl px-4 pt-32 pb-20">
    <h1 class="text-4xl font-medium">Downloads</h1>
    <p class="mt-4 text-xl">Use this compatibility route to jump to the latest HyperZoneLogin build artifacts.</p>
    <div class="mt-8 flex flex-row gap-4">
      <Button variant="filled" href="https://github.com/HyperZoneLogin/HyperzoneLogin/releases" external>Latest Releases</Button>
      <Button variant="outlined" href="/downloads">Module Overview</Button>
    </div>
  </section>
</Layout>
