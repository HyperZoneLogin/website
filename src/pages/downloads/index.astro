---
import Button from "@/components/input/Button.astro";
import Layout from "@/layouts/Layout.astro";

const modules = [
  {
    name: "velocity",
    description: "Core plugin responsible for profiles, storage, command routing, and module lifecycle.",
  },
  {
    name: "auth-yggd",
    description: "Yggdrasil authentication module for Mojang and third-party account systems.",
  },
  {
    name: "auth-offline",
    description: "Offline/local account module for hybrid environments.",
  },
  {
    name: "profile-skin",
    description: "Skin extraction and repair module with profile-property caching.",
  },
  {
    name: "data-merge",
    description: "Migration module for importing existing AuthMe and MultiLogin data.",
  },
  {
    name: "api",
    description: "Public API package for integration and extension development.",
  },
];
---

<Layout
  title="Downloads"
  description="HyperZoneLogin module overview with release and source links."
  keywords={["hyperzonelogin", "downloads", "velocity", "modules", "minecraft"]}
  canonical="/downloads"
>
  <header class="mx-auto flex max-w-5xl flex-col items-center gap-2 px-4 pt-32 pb-16 lg:pt-28 lg:pb-12">
    <h1 class="text-4xl leading-normal font-medium lg:text-5xl lg:leading-normal">Downloads</h1>
    <p class="mb-6 text-center text-xl">
      Browse HyperZoneLogin modules, read setup docs, and grab published builds from GitHub Releases.
    </p>
    <div class="grid w-full gap-3 md:grid-cols-2">
      {
        modules.map((module) => (
          <article class="rounded-md border border-gray-300 p-5 dark:border-gray-700">
            <h2 class="text-xl font-semibold">{module.name}</h2>
            <p class="mt-2 text-gray-700 dark:text-gray-200">{module.description}</p>
          </article>
        ))
      }
    </div>
    <div class="mt-8 flex flex-row gap-4">
      <Button variant="outlined" href="https://docs.h2l.icu" external> Documentation </Button>
      <Button variant="filled" href="https://github.com/HyperZoneLogin/HyperzoneLogin/releases" external> Latest Releases </Button>
      <Button variant="outlined" href="https://github.com/HyperZoneLogin/HyperzoneLogin" external> Repository </Button>
    </div>
  </header>
</Layout>
