---
import { Image } from "astro:assets";

import Button from "@/components/input/Button.astro";
import Layout from "@/layouts/Layout.astro";

import ChattingIllustration from "@/assets/illustrations/undraw/chatting.svg";
import CodeReviewIllustration from "@/assets/illustrations/undraw/code-review.svg";
import KnowledgeIllustration from "@/assets/illustrations/undraw/knowledge.svg";
import SavingsIllustration from "@/assets/illustrations/undraw/savings.svg";
---

<Layout
  title="Contributing"
  description="Contribute to HyperZoneLogin through code, docs, support, and sponsorship."
  keywords={["hyperzonelogin", "contributing", "sponsor", "minecraft", "velocity"]}
  canonical="/contribute"
>
  <header class="mx-auto flex max-w-7xl flex-row gap-16 px-4 pt-32 pb-16 lg:pt-28 lg:pb-16">
    <div class="flex-1">
      <h1 class="text-4xl leading-normal font-medium lg:text-5xl lg:leading-normal">You can contribute</h1>
      <p class="mt-4 text-xl">
        HyperZoneLogin grows through community feedback and contributions. You can help through development, support, testing, and
        documentation.
      </p>
      <div class="mt-8 flex flex-row gap-4"></div>
    </div>
    <div class="hidden flex-1 justify-end lg:flex"></div>
  </header>

  <section id="donate" class="mx-auto flex max-w-7xl flex-col-reverse items-center gap-8 px-4 py-4 lg:flex-row">
    <div class="flex-1">
      <h2 class="text-2xl font-medium md:text-4xl">...Financially</h2>
      <p class="mt-3 text-gray-900 md:mt-6 md:text-lg dark:text-gray-100">
        Financial support helps keep development sustainable and funds ongoing maintenance, infrastructure, and long-term improvements.
      </p>
      <div class="mt-8 flex flex-row gap-4">
        <Button variant="filled" href="/sponsors" dense> Learn More </Button>
      </div>
    </div>
    <div class="flex w-full justify-start lg:flex-1 lg:justify-end">
      <Image src={SavingsIllustration} alt={"Savings Illustration"} class="max-h-32 lg:max-h-none lg:max-w-[18rem]" />
    </div>
  </section>
  <section id="code" class="mx-auto mt-12 flex max-w-7xl flex-col-reverse items-center gap-8 px-4 py-4 lg:flex-row">
    <div class="flex-1">
      <h2 class="text-2xl font-medium md:text-4xl">...Code</h2>
      <p class="mt-3 text-gray-900 md:mt-6 md:text-lg dark:text-gray-100">
        We welcome improvements across the core plugin and module ecosystem. Before opening a pull request, discuss larger changes in an issue.
      </p>
      <div class="mt-8 flex flex-row gap-4">
        <Button variant="filled" href="https://github.com/HyperZoneLogin/HyperzoneLogin" external dense> Repository </Button>
      </div>
    </div>
    <div class="flex w-full justify-start lg:flex-1 lg:justify-end">
      <Image src={CodeReviewIllustration} alt={"Code Review Illustration"} class="max-h-32 lg:max-h-none lg:max-w-[18rem]" />
    </div>
  </section>
  <section id="support" class="mx-auto mt-12 flex max-w-7xl flex-col-reverse items-center gap-8 px-4 py-4 lg:flex-row">
    <div class="lg:flex-1">
      <h2 class="text-2xl font-medium md:text-4xl">...Support</h2>
      <p class="mt-3 text-gray-900 md:mt-6 md:text-lg dark:text-gray-100">
        Help other server operators by answering setup questions, sharing migration tips, and testing release candidates in real-world
        networks.
      </p>
      <div class="mt-8 flex flex-row gap-4">
        <Button variant="filled" href="/community" dense> Our Community </Button>
      </div>
    </div>
    <div class="flex w-full justify-start lg:flex-1 lg:justify-end">
      <Image src={ChattingIllustration} alt={"Chatting Illustration"} class="max-h-32 lg:max-h-none lg:max-w-[18rem]" />
    </div>
  </section>
  <section id="documentation" class="mx-auto mt-12 flex max-w-7xl flex-col-reverse items-center gap-8 px-4 py-4 lg:flex-row">
    <div class="flex-1">
      <h2 class="text-2xl font-medium md:text-4xl">...Documentation</h2>
      <p class="mt-3 text-gray-900 md:mt-6 md:text-lg dark:text-gray-100">
        Clear docs reduce support cost for everyone. You can help by improving setup guides, writing migration notes, and updating module
        references.
      </p>
      <div class="mt-8 flex flex-row gap-4">
        <Button variant="filled" href="https://docs.h2l.icu" external dense>
          Documentation Portal
        </Button>
      </div>
    </div>
    <div class="flex w-full justify-start lg:flex-1 lg:justify-end">
      <Image src={KnowledgeIllustration} alt={"Knowledge Illustration"} class="max-h-32 lg:max-h-none lg:max-w-[18rem]" />
    </div>
  </section>
</Layout>
