---
import Layout from "@/layouts/Layout.astro";
import Button from "@/components/input/Button.astro";
---

<Layout
  title="Legacy Software Alias"
  description="Legacy route kept for compatibility after the HyperZoneLogin migration."
  keywords={["hyperzonelogin", "software", "legacy-route"]}
  canonical="/software/waterfall"
>
  <section class="mx-auto max-w-4xl px-4 pt-32 pb-20">
    <h1 class="text-4xl font-medium">Legacy Software Route</h1>
    <p class="mt-4 text-xl">This page is retained for compatibility and now references the HyperZoneLogin module and release pages.</p>
    <div class="mt-8 flex flex-row gap-4">
      <Button variant="filled" href="/downloads">View Modules</Button>
      <Button variant="outlined" href="https://github.com/HyperZoneLogin/HyperzoneLogin" external>Repository</Button>
    </div>
  </section>
</Layout>
