---
import Layout from "@/layouts/Layout.astro";
import Button from "@/components/input/Button.astro";
---

<Layout
  title="Legacy Software Alias"
  description="Legacy route kept for compatibility after the HyperZoneLogin site migration."
  keywords={["hyperzonelogin", "software", "legacy-route"]}
  canonical="/software/paper"
>
  <section class="mx-auto max-w-4xl px-4 pt-32 pb-20">
    <h1 class="text-4xl font-medium">Legacy Software Route</h1>
    <p class="mt-4 text-xl">
      This endpoint remains available for old links. HyperZoneLogin now uses a module-first structure rather than Paper/Folia/Velocity
      product pages.
    </p>
    <div class="mt-8 flex flex-row gap-4">
      <Button variant="filled" href="/downloads">View Modules</Button>
      <Button variant="outlined" href="https://github.com/HyperZoneLogin/HyperzoneLogin/releases" external>Latest Releases</Button>
    </div>
  </section>
</Layout>
