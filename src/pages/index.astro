---
import Button from "@/components/input/Button.astro";
import Layout from "@/layouts/Layout.astro";
import HomeImage1 from "@/assets/images/home-1.png";
import HomeImage2 from "@/assets/images/home-2.png";
---

<Layout
  title="Home"
  description="HyperZoneLogin is a modular multi-login framework for Velocity-based Minecraft proxy networks."
  keywords={["hyperzonelogin", "velocity", "minecraft", "authentication", "yggdrasil", "offline-login"]}
  canonical="/"
>
  <header class="mx-auto flex max-w-7xl flex-row px-4 pt-32 pb-20 lg:pt-40 lg:pb-28">
    <div class="flex-1">
      <h1 class="text-4xl leading-normal font-medium lg:text-5xl lg:leading-normal">
        One proxy,
        <span class="text-blue-500">multiple login methods.</span>
      </h1>
      <p class="mt-4 text-xl">
        HyperZoneLogin unifies Mojang authentication, third-party Yggdrasil providers, offline accounts, profile handling, and skin recovery
        into a single Velocity-layer framework.
      </p>
      <div class="mt-8 flex flex-row gap-4">
        <Button variant="filled" href="/downloads"> Explore Modules </Button>
        <Button variant="outlined" href="https://docs.h2l.icu" external> Documentation </Button>
        <Button variant="outlined" href="https://github.com/HyperZoneLogin/HyperzoneLogin/releases" external> Latest Release </Button>
      </div>
    </div>
  </header>
  <section id="facts" class="mx-auto flex max-w-7xl flex-col gap-8 px-4 py-8 md:gap-12 md:py-14">
    <div class="flex flex-col items-center gap-6 md:flex-row md:gap-8 xl:gap-24">
      <div class="relative aspect-video w-full flex-1 overflow-clip rounded-xl bg-gray-900">
        <img src={HomeImage1.src} alt="HyperZoneLogin architecture" loading="lazy" decoding="async" class="h-full w-full object-cover" />
      </div>
      <div class="flex-1">
        <h2 class="text-2xl font-semibold md:text-4xl">Built for long-term maintainability</h2>
        <p class="mt-3 text-gray-900 md:mt-6 md:text-xl dark:text-gray-100">
          Instead of splitting authentication logic across many backend plugins, HyperZoneLogin centralizes identity flow at the proxy layer
          with a modular core and optional extensions.
        </p>
        <div class="mt-8 flex flex-row gap-4">
          <Button variant="filled" href="https://github.com/HyperZoneLogin/HyperzoneLogin" external> View Repository </Button>
        </div>
      </div>
    </div>
    <div class="flex flex-col items-center gap-6 md:flex-row-reverse md:gap-8 xl:gap-24">
      <div class="relative aspect-video w-full flex-1 overflow-clip rounded-xl bg-gray-900">
        <img src={HomeImage2.src} alt="Authentication and profile pipeline" loading="lazy" decoding="async" class="h-full w-full object-cover" />
      </div>
      <div class="flex-1">
        <h2 class="text-2xl font-semibold md:text-4xl">Designed for hybrid player ecosystems</h2>
        <p class="mt-3 text-gray-900 md:mt-6 md:text-xl dark:text-gray-100">
          The framework supports official accounts, third-party skin-site auth, and offline users in one profile model. It also includes
          migration paths from AuthMe and MultiLogin.
        </p>
        <div class="mt-8 flex flex-row gap-4">
          <Button variant="filled" href="/community"> Join Community </Button>
        </div>
      </div>
    </div>
  </section>
</Layout>
