import Button from "@/components/input/Button.astro";
import Layout from "@/layouts/Layout.astro";
import FeatureCard from "@/components/data/FeatureCard.astro";
---

<Layout
  title="Sponsors"
  description="Support HyperZoneLogin development and long-term maintenance."
  keywords={["hyperzonelogin", "sponsor", "support", "minecraft", "velocity"]}
  canonical="/sponsors"
>
  <header class="mx-auto flex max-w-7xl flex-row gap-16 px-4 pt-32 pb-16 lg:pt-48 lg:pb-32">
    <div class="flex-1">
      <h1 class="text-4xl leading-normal font-medium lg:text-5xl lg:leading-normal">Sponsors</h1>
      <p class="mt-4 text-xl">
        HyperZoneLogin is community-driven. Sponsorship helps cover development time, infrastructure, and ongoing support for production
        deployments.
      </p>
      <div class="mt-8 flex flex-row gap-4">
        <Button variant="filled" href="https://ko-fi.com/ksqeib" external> Ko-fi </Button>
        <Button variant="outlined" href="https://afdian.com/a/ksqeib445" external> Afdian </Button>
      </div>
    </div>
    <div class="hidden flex-1 justify-end lg:flex"></div>
  </header>
  <section id="why" class="bg-primary-200 dark:bg-background-dark-80 w-full pt-10 pb-5">
    <div class="mx-auto max-w-7xl py-2">
      <h2 class="px-6 text-xl font-semibold md:text-2xl lg:px-4">Why You Should Donate</h2>
      <div class="mt-6 grid gap-2 px-2 md:grid-cols-3 xl:gap-4">
        <FeatureCard
          icon="icons/heroicons/globe-americas"
          label="Sustainability"
          description="Donations keep HyperZoneLogin actively maintained, documented, and tested across real server environments."
        />
        <FeatureCard
          icon="icons/heroicons/bolt"
          label="Future plans"
          description="Support directly accelerates roadmap work such as ecosystem integrations, migration tooling, and quality-of-life features."
        />
        <FeatureCard
          icon="icons/heroicons/heart"
          label="Giving back"
          description="Even if you cannot donate, issue reports, high-quality pull requests, and documentation contributions are valuable support."
        />
      </div>
    </div>
  </section>
  <section id="sponsors" class="mx-auto max-w-7xl px-4 py-8">
    <h2 class="text-xl font-semibold md:text-2xl">Support Channels</h2>
    <p class="mt-3 text-lg text-gray-900 dark:text-gray-100">
      Current public support links confirmed by the project are listed below.
    </p>
    <div class="mt-8 flex flex-row gap-4">
      <Button variant="filled" href="https://ko-fi.com/ksqeib" external>Support on Ko-fi</Button>
      <Button variant="outlined" href="https://afdian.com/a/ksqeib445" external>Support on Afdian</Button>
    </div>
  </section>
</Layout>
