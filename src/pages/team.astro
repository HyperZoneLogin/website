---
import Button from "@/components/input/Button.astro";
import Layout from "@/layouts/Layout.astro";
const roles = [
  {
    name: "Core Maintainers",
    description: "Design architecture, guide releases, and maintain core compatibility.",
  },
  {
    name: "Module Maintainers",
    description: "Own module-level behavior across auth, profile, and migration subsystems.",
  },
  {
    name: "Community Contributors",
    description: "Submit fixes, testing feedback, documentation updates, and translations.",
  },
];
---

<Layout
  title="Team"
  description="Meet the maintainers and contributors behind HyperZoneLogin."
  keywords={["hyperzonelogin", "team", "contributors", "velocity", "minecraft"]}
  canonical="/team"
>
  <header class="mx-auto flex max-w-7xl flex-row gap-16 px-4 pt-32 pb-26 lg:pt-28 lg:pb-16">
    <div class="flex-1">
      <h1 class="text-4xl leading-normal font-medium lg:text-5xl lg:leading-normal">Meet our team</h1>
      <p class="mt-4 text-xl">
        HyperZoneLogin is maintained by open source contributors focused on reliable proxy-level authentication and profile infrastructure.
      </p>
      <div class="mt-8 flex flex-row gap-4">
        <Button variant="filled" href="/sponsors"> Sponsor </Button>
        <Button variant="outlined" href="https://github.com/HyperZoneLogin" external> GitHub </Button>
      </div>
    </div>
    <div class="hidden flex-1 justify-end lg:flex"></div>
  </header>
  <section class="mx-auto max-w-7xl px-4 py-8">
    <h2 class="mb-4 text-2xl font-medium">How the project is organized</h2>
    <div class="grid gap-4 md:grid-cols-3">
      {
        roles.map((role) => (
          <article class="rounded-md border border-gray-300 p-4 dark:border-gray-700">
            <h3 class="text-lg font-semibold">{role.name}</h3>
            <p class="mt-2">{role.description}</p>
          </article>
        ))
      }
    </div>
  </section>
  <section class="mx-auto max-w-7xl px-4 py-8">
    <h2 class="mb-2 text-2xl font-medium">Contributors</h2>
    <p>
      We welcome high-quality pull requests, issue reports, documentation edits, and testing feedback from server operators and developers.
    </p>
    <div class="mt-6 flex flex-row gap-4">
      <Button variant="filled" href="https://github.com/HyperZoneLogin/HyperzoneLogin/graphs/contributors" external>
        Contributor Graph
      </Button>
      <Button variant="outlined" href="https://github.com/HyperZoneLogin/HyperzoneLogin/issues" external>
        Open Issues
      </Button>
    </div>
  </section>
</Layout>
