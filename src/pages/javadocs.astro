import Layout from "@/layouts/Layout.astro";
import Button from "@/components/input/Button.astro";
---

<Layout
  title="Developer API"
  description="Developer resources and API entry points for HyperZoneLogin integrations."
  keywords={["hyperzonelogin", "api", "developer", "velocity", "javadocs"]}
  canonical="/javadocs"
>
  <header class="mx-auto flex max-w-7xl flex-col items-center gap-2 px-4 pt-32 pb-16 lg:pt-48 lg:pb-26">
    <h1 class="text-4xl leading-normal font-medium lg:text-5xl lg:leading-normal">Developer API</h1>
    <p class="mb-6 text-center text-xl">
      Start from the official docs portal, then use API sources for deep integration details.
    </p>
    <div class="grid w-full max-w-4xl gap-3 px-2 md:grid-cols-2">
      <article class="rounded-md border border-gray-300 p-5 dark:border-gray-700">
        <h2 class="text-xl font-semibold">API module</h2>
        <p class="mt-2">Shared contracts and extension interfaces for custom authentication modules.</p>
      </article>
      <article class="rounded-md border border-gray-300 p-5 dark:border-gray-700">
        <h2 class="text-xl font-semibold">Official documentation</h2>
        <p class="mt-2">Setup guides, module docs, and migration references are published at docs.h2l.icu.</p>
      </article>
    </div>
    <div class="mt-8 flex flex-row gap-4">
      <Button variant="filled" href="https://docs.h2l.icu" external> Documentation Portal </Button>
      <Button variant="filled" href="https://github.com/HyperZoneLogin/HyperzoneLogin/tree/master/api" external> API Module </Button>
      <Button variant="outlined" href="https://github.com/HyperZoneLogin/HyperzoneLogin" external> Full Repository </Button>
    </div>
  </header>
</Layout>
