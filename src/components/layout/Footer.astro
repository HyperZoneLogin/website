---
import { Icon } from "astro-icon/components";

const hash = import.meta.env.GIT_COMMIT_HASH;
---

<footer class="footer bg-background-dark-80 mt-8 border-t py-12">
  <div class="m-auto max-w-7xl px-4">
    <div class="grid gap-10 text-sm text-white sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
      <div>
        <span class="font-semibold">Getting Started</span>
        <ul class="mt-4 space-y-2 leading-5 text-gray-400">
          <li>
            <a href="/downloads">Module Overview</a>
          </li>
          <li>
            <a href="https://github.com/HyperZoneLogin/HyperzoneLogin/releases" target="_blank" rel="noreferrer"> Releases </a>
          </li>
          <li>
            <a href="/javadocs">Developer API</a>
          </li>
        </ul>
      </div>
      <div>
        <span class="font-semibold">Community</span>
        <ul class="mt-4 space-y-2 leading-5 text-gray-400">
          <li>
            <a href="/community">Community Hub</a>
          </li>
          <li>
            <a href="https://discord.gg/dCAeNyR9TA" target="_blank" rel="noreferrer"> Discord </a>
          </li>
          <li>
            <a href="https://qm.qq.com/q/GZWVfEyokS" target="_blank" rel="noreferrer"> QQ Group </a>
          </li>
          <li>
            <a href="https://github.com/HyperZoneLogin" target="_blank" rel="noreferrer"> GitHub Organization </a>
          </li>
        </ul>
      </div>
      <div>
        <span class="font-semibold">HyperZoneLogin</span>
        <ul class="mt-4 space-y-2 leading-5 text-gray-400">
          <li>
            <a href="/team">Our Team</a>
          </li>
          <li>
            <a href="/contribute">Contribute</a>
          </li>
          <li>
            <a href="/sponsors">Sponsors</a>
          </li>
          <li>
            <a href="/news">Updates</a>
          </li>
        </ul>
      </div>
      <div>
        <span class="font-semibold">Project Resources</span>
        <ul class="mt-4 space-y-2 leading-5 text-gray-400">
          <li>
            <a href="https://github.com/HyperZoneLogin/HyperzoneLogin/blob/master/LICENSE" target="_blank" rel="noreferrer">License</a>
          </li>
          <li>
            <a href="https://github.com/HyperZoneLogin/HyperzoneLogin/issues" target="_blank" rel="noreferrer">Issue Tracker</a>
          </li>
          <li>
            <a href="https://github.com/HyperZoneLogin/HyperzoneLogin/discussions" target="_blank" rel="noreferrer">Discussions</a>
          </li>
          <li>
            <a href="/community/guidelines">Community Guidelines</a>
          </li>
        </ul>
      </div>
    </div>
    <div class="mt-8 flex flex-row items-center gap-2 border-t border-gray-600/50 pt-10">
      <Icon name="brand/logo-marker-dark" class="h-12 w-auto cursor-pointer" />
      <div class="flex-1"></div>
      <div class="flex flex-col">
        <span class="text-right text-sm text-gray-300">
          © {new Date().getFullYear()} HyperZoneLogin Contributors
        </span>
        <span class="prose-link commit text-sm text-gray-300">Build {hash}</span>
      </div>
    </div>
    <div class="mt-4 flex flex-row items-center gap-2 pt-4">
      <span class="text-sm text-gray-300">
        HyperZoneLogin is an independent open source project. Minecraft and Mojang are trademarks of their respective owners.
      </span>
    </div>
  </div>
</footer>

<style>
  @reference "tailwindcss";
  .footer a {
    @apply transition hover:text-gray-200;
  }
</style>
